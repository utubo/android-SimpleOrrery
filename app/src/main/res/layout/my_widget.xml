<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    style="@style/MyAppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0000"
    tools:ignore="ContentDescription">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.4"
        android:src="@drawable/space"
        android:tint="#000" />

    <ImageView
        android:id="@+id/sun"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/sun" />

    <ImageView
        android:id="@+id/earth"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/earth"
        android:tint="@color/earth" />

    <ImageView
        android:id="@+id/mercury"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/mercury" />

    <ImageView
        android:id="@+id/venus"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/venus" />

    <ImageView
        android:id="@+id/mars"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/mars" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/belt" />

    <ImageView
        android:id="@+id/jupiter"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/jupiter" />

    <ImageView
        android:id="@+id/saturn"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/saturn" />

    <ImageView
        android:id="@+id/uranus"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/uranus" />

    <ImageView
        android:id="@+id/neptune"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/neptune" />

</RelativeLayout>